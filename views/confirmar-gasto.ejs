<%- include('partials/header', { showBack: true, backHref: '/escanear' }) %>

<main class="main main--confirm">

  <!-- Hero -->
  <div class="confirm-hero">
    <h2 class="confirm-hero__title">Confirmar gasto</h2>
    <p class="confirm-hero__sub">Revisa los datos detectados antes de guardar</p>
    <span class="ia-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#007442" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      Datos obtenidos por IA
    </span>
  </div>

  <!-- Ticket preview placeholder -->
  <div class="ticket-preview">
    <div class="ticket-preview__gradient"></div>
    <a href="#" class="ticket-preview__link">
      <svg width="14" height="10" viewBox="0 0 24 24" fill="none" stroke="#0456C5" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      Ver ticket original
    </a>
  </div>

  <form method="POST" action="/escanear/confirmar">

    <!-- Amount -->
    <div class="amount-card">
      <span class="amount-card__label">Monto total</span>
      <div class="amount-card__row">
        <span class="amount-card__prefix">$</span>
        <input type="number" name="monto" step="0.01" class="amount-card__input" value="<%= datos.monto || 0 %>" required />
      </div>
    </div>

    <!-- Detail fields -->
    <div class="detail-card">

      <div class="detail-field">
        <label class="detail-label">Establecimiento</label>
        <div class="detail-input-wrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#424653" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          <input type="text" name="establecimiento" class="detail-input" value="<%= datos.establecimiento || '' %>" />
        </div>
      </div>

      <div class="detail-field">
        <label class="detail-label">Concepto</label>
        <div class="detail-input-wrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#424653" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
          <input type="text" name="concepto" class="detail-input" value="<%= datos.concepto || '' %>" />
        </div>
      </div>

      <div class="detail-row">
        <div class="detail-field detail-field--half">
          <label class="detail-label">Fecha</label>
          <div class="detail-input-wrap">
            <svg width="14" height="16" viewBox="0 0 24 24" fill="none" stroke="#424653" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <input type="date" name="fecha" class="detail-input" value="<%= datos.fecha || new Date().toISOString().split('T')[0] %>" />
          </div>
        </div>
        <div class="detail-field detail-field--half">
          <label class="detail-label">Categoría sugerida</label>
          <div class="detail-input-wrap detail-input-wrap--cat">
            <svg width="14" height="16" viewBox="0 0 24 24" fill="none" stroke="#007442" stroke-width="2" stroke-linecap="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
            <select name="categoria" class="detail-input">
              <% ['Comida','Transporte','Servicios','Salud','Entretenimiento','Otros'].forEach(cat => { %>
                <option value="<%= cat %>" <%= datos.categoria === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
        </div>
      </div>

      <div class="detail-field">
        <label class="detail-label">Método de pago</label>
        <div class="detail-input-wrap">
          <svg width="18" height="14" viewBox="0 0 24 24" fill="none" stroke="#424653" stroke-width="2" stroke-linecap="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <select name="metodo_pago" class="detail-input">
            <% ['Efectivo','Tarjeta','Transferencia'].forEach(m => { %>
              <option value="<%= m %>" <%= datos.metodo_pago === m ? 'selected' : '' %>><%= m %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="detail-field">
        <label class="detail-label">Notas</label>
        <div class="detail-input-wrap">
          <svg width="14" height="16" viewBox="0 0 24 24" fill="none" stroke="#424653" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
          <textarea name="notas" class="detail-input detail-textarea"><%= datos.notas || 'Escaneado desde ticket' %></textarea>
        </div>
      </div>

    </div>

    <!-- Actions -->
    <div class="form-actions">
      <button type="submit" class="btn btn--primary">Guardar gasto</button>
      <a href="/gastos/nuevo" class="btn btn--outline">Corregir manualmente</a>
    </div>

  </form>
</main>

<%- include('partials/bottomnav') %>
