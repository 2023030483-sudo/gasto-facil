<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title><%= title %> — Gasto Fácil</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0456C5" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  <script src="/js/pwa-register.js" defer></script>
</head>
<body>
  <!-- Top App Bar -->
  <header class="top-bar">
    <div class="top-bar__left">
      <% if (locals.showBack) { %>
        <a href="<%= locals.backHref || '/' %>" class="btn-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        </a>
        <span class="top-bar__page-title"><%= title %></span>
      <% } else { %>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="#0456C5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
        <span class="top-bar__brand">Gasto Fácil</span>
      <% } %>
    </div>
    <div class="top-bar__right">
      <% if (locals.showTicketLabel) { %>
        <span class="top-bar__label">Escanear ticket</span>
      <% } else { %>
        <button class="btn-icon">
          <svg width="16" height="20" viewBox="0 0 24 24" fill="none" stroke="#424653" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </button>
      <% } %>
    </div>
  </header>
