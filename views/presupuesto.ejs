<%- include('partials/header', { showBack: false }) %>

  <main class="main main--budget">
    <div class="page-header">
      <h1 class="page-header__title">Presupuesto mensual</h1>
      <p class="page-header__sub">Controla cuánto deseas gastar durante el mes</p>
    </div>

    <div id="pageError" class="error-message" style="display:none; color:#BA1A1A"></div>

    <section id="budgetSetupCard" class="budget-setup-card" hidden>
      <div class="budget-wallet" aria-hidden="true">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 7V5a2 2 0 0 0-2-2H5a3 3 0 0 0 0 6h15v10a2 2 0 0 1-2 2H5a3 3 0 0 1-3-3V6"/>
          <path d="M16 13h4"/>
          <circle cx="16" cy="13" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <div class="budget-setup-card__copy">
        <h2 id="budgetFormTitle">¿Cuál es el monto mensual que quieres gastar?</h2>
        <p id="budgetFormText">Define una cantidad para llevar el control de tus gastos durante el mes.</p>
      </div>

      <form id="budgetForm" class="budget-form" novalidate>
        <label for="budgetAmount">Monto mensual</label>
        <div class="budget-input-wrap">
          <span>$</span>
          <input id="budgetAmount" type="number" inputmode="decimal" min="0.01" step="0.01" placeholder="Ej. 5000" required />
          <small>MXN</small>
        </div>
        <p id="budgetMessage" class="budget-message" role="status" aria-live="polite"></p>
        <div class="budget-form__actions">
          <button id="budgetSaveButton" class="btn btn--primary" type="submit">Guardar presupuesto</button>
          <button id="budgetCancelButton" class="btn btn--outline" type="button" hidden>Cancelar</button>
        </div>
      </form>
    </section>

    <section id="budgetSummaryCard" class="budget-summary-card" hidden>
      <div class="budget-summary-card__header">
        <div>
          <p class="budget-summary-card__eyebrow">PRESUPUESTO DEL MES</p>
          <h2 id="budgetValue">$0.00</h2>
        </div>
        <div class="budget-summary-card__wallet" aria-hidden="true">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7V5a2 2 0 0 0-2-2H5a3 3 0 0 0 0 6h15v10a2 2 0 0 1-2 2H5a3 3 0 0 1-3-3V6"/><path d="M16 13h4"/></svg>
        </div>
      </div>

      <div class="budget-progress">
        <div class="budget-progress__labels">
          <span id="budgetPercent">0% utilizado</span>
          <span>100%</span>
        </div>
        <div class="budget-progress__track"><div id="budgetProgressFill" class="budget-progress__fill"></div></div>
      </div>

      <div class="budget-stats">
        <div class="budget-stat">
          <span>Gastado</span>
          <strong id="budgetSpent">$0.00</strong>
        </div>
        <div class="budget-stat">
          <span>Disponible</span>
          <strong id="budgetRemaining" class="budget-stat__value--positive">$0.00</strong>
        </div>
      </div>

      <p id="budgetStatus" class="budget-status"></p>

      <div class="budget-summary-card__actions">
        <button id="budgetEditButton" class="budget-action budget-action--edit" type="button">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          Modificar
        </button>
        <button id="budgetDeleteButton" class="budget-action budget-action--delete" type="button">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
          Eliminar
        </button>
      </div>
    </section>

    <section class="budget-notifications-section">
      <div class="budget-notifications-section__header">
        <div>
          <h2>Notificaciones</h2>
          <p>Avisos de avance de tu presupuesto</p>
        </div>
        <button id="clearBudgetNotifications" class="budget-clear-button" type="button" hidden>Limpiar</button>
      </div>

      <button id="enableDeviceNotifications" class="budget-device-button" type="button">Activar avisos del dispositivo</button>
      <div id="budgetNotificationsList" class="budget-notifications-list"></div>
      <div id="budgetNotificationsEmpty" class="budget-notifications-empty">
        <div aria-hidden="true">🔔</div>
        <p>Aquí aparecerán los avisos cuando alcances el 50%, 70%, 80%, 90%, 95% y 100% de tu presupuesto.</p>
      </div>
    </section>
  </main>

  <script type="module" src="/js/presupuesto.js?v=2"></script>

<%- include('partials/bottomnav') %>
